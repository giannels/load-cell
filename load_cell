#include "HX711.h"

// --- PIN SENSOR A (Target 2kg) ---
#define DT_A D2
#define SCK_A D1
// --- PIN SENSOR B (Target 5kg) ---
#define DT_B D4
#define SCK_B D3

// --- PIN LED ---
#define LED_MERAH D5
#define LED_BIRU  D6  // Untuk Sensor A (2kg)
#define LED_HIJAU D7  // Untuk Sensor B (5kg)

HX711 hxA;
HX711 hxB;

// Masukkan faktor kalibrasi masing-masing sensor
// Lakukan kalibrasi
float faktorA = -42000.0; 
float faktorB = -42000.0; 

void setup() {
  Serial.begin(115200);
  
  pinMode(LED_MERAH, OUTPUT);
  pinMode(LED_BIRU, OUTPUT);
  pinMode(LED_HIJAU, OUTPUT);

  // Tahap Persiapan: Nyalakan semua lampu
  digitalWrite(LED_MERAH, HIGH);
  digitalWrite(LED_BIRU, HIGH);
  digitalWrite(LED_HIJAU, HIGH);

  hxA.begin(DT_A, SCK_A);
  hxB.begin(DT_B, SCK_B);

  Serial.println("\n--- MEMULAI SISTEM DUAL SENSOR ---");
  Serial.println("Mohon Tunggu... Sedang menstabilkan sensor.");

  delay(5000); // Waktu tunggu stabilitas tegangan

  // Proses Tare Sensor A
  if (hxA.is_ready()) {
    hxA.set_scale();
    hxA.tare(60); 
    hxA.set_scale(faktorA);
    Serial.println("Sensor A (2kg) Siap.");
  }

  // Proses Tare Sensor B
  if (hxB.is_ready()) {
    hxB.set_scale();
    hxB.tare(60); 
    hxB.set_scale(faktorB);
    Serial.println("Sensor B (5kg) Siap.");
  }

  // Persiapan selesai: Matikan semua lampu
  digitalWrite(LED_MERAH, LOW);
  digitalWrite(LED_BIRU, LOW);
  digitalWrite(LED_HIJAU, LOW);
}

void loop() {
  float beratA = 0.0;
  float beratB = 0.0;

  // --- PEMBACAAN SENSOR A ---
  if (hxA.is_ready()) {
    float readingA = hxA.get_units(2);
    // Noise Gate: Jika di bawah 0.4kg anggap 0 (mengatasi turun pelan-pelan)
    if (readingA < 0.4) readingA = 0.0;
    beratA = round(readingA * 10.0) / 10.0;
  }

  // --- PEMBACAAN SENSOR B ---
  if (hxB.is_ready()) {
    float readingB = hxB.get_units(2);
    // Noise Gate: Jika di bawah 0.4kg anggap 0
    if (readingB < 0.4) readingB = 0.0;
    beratB = round(readingB * 10.0) / 10.0;
  }

  // Tampilkan di Serial Monitor
  Serial.print("Berat A: "); Serial.print(beratA, 1);
  Serial.print(" kg | Berat B: "); Serial.print(beratB, 1);
  Serial.println(" kg");

  // Tentukan status standarisasi masing-masing sensor
  bool okA = (beratA >= 1.0 && beratA <= 2.0);
  
  bool okB = (beratB >= 3.0 && beratB <= 4.0);

  // Cek apakah ada benda di atas sensor (di atas noise gate 0.4kg)
  bool adaBendaA = (beratA >= 0.4);
  bool adaBendaB = (beratB >= 0.4);

  // --- LOGIKA LED MERAH (Indikator Standby atau Salah Berat) ---
  // Menyala jika: 
  // - Keduanya kosong 
  // - ATAU Ada benda di A tapi beratnya salah (!okA)
  // - ATAU Ada benda di B tapi beratnya salah (!okB)
  if ((!adaBendaA && !adaBendaB) || (adaBendaA && !okA) || (adaBendaB && !okB)) {
    digitalWrite(LED_MERAH, HIGH);
  } else {
    digitalWrite(LED_MERAH, LOW);
  }

  // --- LOGIKA LED BIRU (Sensor A OK) ---
  if (okA) {
    digitalWrite(LED_BIRU, HIGH);
  } else {
    digitalWrite(LED_BIRU, LOW);
  }

  // --- LOGIKA LED HIJAU (Sensor B OK) ---
  if (okB) {
    digitalWrite(LED_HIJAU, HIGH);
  } else {
    digitalWrite(LED_HIJAU, LOW);
  }

  yield();
  delay(100); 
}
